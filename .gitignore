# .gitignore for B7KHSX Streamlit App

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/

# IDE
.vscode/
.idea/

# Environment
.env
*.env

# Database (local SQLite - keep database_new.db for cloud)
database.db
*.sqlite
*.sqlite3
# Note: database_new.db is NOT ignored - needed for cloud deployment

# Downloads and temp files
downloads/
*.bak

# Excel files (data files - too large for git)
EXCEL/
*.xlsm
*.xlsx

# Secrets (never commit!)
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Backup files
*_backup*
