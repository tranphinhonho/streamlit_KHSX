# .gitignore for B7KHSX Streamlit App

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/

# IDE
.vscode/
.idea/

# Environment
.env
*.env

# Database (local SQLite)
database.db
database_new.db
*.sqlite
*.sqlite3

# Downloads and temp files
downloads/
*.bak

# Excel files (data files - too large for git)
EXCEL/
*.xlsm
*.xlsx

# Secrets (never commit!)
.streamlit/secrets.toml

# Config with API keys
admin/config.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Backup files
*_backup*

# Frontend node_modules
frontend/node_modules/

# Backend build
backend/B7KHSX.Api/bin/
backend/B7KHSX.Api/obj/
